@page
@model Web_prototype.Pages.LoginModel
@{
    ViewData["Title"] = "Вход";
    Layout = "_Layout";
}

<section class="auth-shell">
    <div class="auth-card">
        <aside class="auth-aside">
            <div>
                <h1 class="auth-title">Продолжите работу со своими сборками</h1>
                
            </div>
        </aside>

        <div class="auth-form-panel">
            <div class="section-stack">
                <div>
                    <h2>Добро пожаловать</h2>
                    <p class="section-subtitle">Используйте свои текущие учётные данные, чтобы продолжить работу.</p>
                </div>

                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
                }

                @Html.ValidationSummary(excludePropertyErrors: true, message: string.Empty, htmlAttributes: new { @class = "text-danger" })

                <form method="post" class="auth-form">
                    @Html.AntiForgeryToken()

                    <div class="form-group">
                        <label for="Input_Email">Эл. почта</label>
                        @Html.TextBoxFor(m => m.Input.Email, new { @class = "form-control", id = "Input_Email", type = "email", placeholder = "name@example.com" })
                        @Html.ValidationMessageFor(m => m.Input.Email, string.Empty, new { @class = "text-danger" })
                    </div>

                    <div class="form-group">
                        <label for="Input_Password">Пароль</label>
                        @Html.PasswordFor(m => m.Input.Password, new { @class = "form-control", id = "Input_Password", placeholder = "Введите пароль" })
                        @Html.ValidationMessageFor(m => m.Input.Password, string.Empty, new { @class = "text-danger" })
                    </div>

                    <button type="submit" class="btn btn-primary">Войти</button>
                </form>

                <div class="auth-footer">
                    <span>Нет аккаунта?</span>
                    <a href="/Register">Перейти к регистрации</a>
                </div>
            </div>
        </div>
    </div>
</section>