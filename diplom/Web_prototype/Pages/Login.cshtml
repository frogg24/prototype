@page
@model Web_prototype.Pages.LoginModel
@{
    ViewData["Title"] = "Login";
    Layout = "_Layout";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h3>Вход</h3>
            </div>
            <div class="card-body">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
                }

                @Html.ValidationSummary(excludePropertyErrors: true, message: string.Empty, htmlAttributes: new { @class = "text-danger" })

                <form method="post">
                    @Html.AntiForgeryToken()
                    <div class="form-group">
                        <label for="Input_Email">Эл. почта:</label>
                        @Html.TextBoxFor(m => m.Input.Email, new { @class = "form-control", id = "Input_Email", type = "email" })
                        @Html.ValidationMessageFor(m => m.Input.Email, string.Empty, new { @class = "text-danger" })
                    </div>
                    <div class="form-group">
                        <label for="Input_Password">Пароль:</label>
                        @Html.PasswordFor(m => m.Input.Password, new { @class = "form-control", id = "Input_Password" })
                        @Html.ValidationMessageFor(m => m.Input.Password, string.Empty, new { @class = "text-danger" })
                    </div>
                    <button type="submit" class="btn btn-primary">Войти</button>
                </form>
                <hr />
                <p>Нет аккаунта? <a href="/Register">Регистрация</a></p>
            </div>
        </div>
    </div>
</div>