@page "{id:int}"
@model Web_prototype.Pages.ProjectPageModel
@using DataModels.enums
@{
    ViewData["Title"] = "Проект";
    Layout = "_Layout";
}

<section class="page-stack">
    <section class="project-hero">
        <div class="project-hero-grid">
            <div class="project-hero-content">
                <h1 class="project-title">@(Model.Project?.Title ?? "Проект")</h1>

                <div class="project-toolbar">
                    <a href="/MyProjects" class="btn btn-secondary btn-sm">← К проектам</a>

                    <form method="post" action="@Url.Page("/Project", new { id = Model.Id, handler = "Assemble" })">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-success btn-sm">Запустить сборку</button>
                    </form>

                    <a href="@Url.Page("/Assembly", new { projectId = Model.Id })" class="btn btn-outline-primary btn-sm">
                        Открыть результат
                    </a>
                </div>
            </div>

            <div class="project-hero-side">
                <div class="info-card">
                    <span class="info-icon">🧬</span>
                    <h3>Рабочая область проекта</h3>
                    <div class="reads-summary mt-3">
                        <span class="inline-badge">Ридов: @Model.Reads.Count</span>
                        <span class="inline-badge">Проект активен</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="card">
        <div class="card-header">
            <div>
                <h3>AB1-файлы</h3>
            </div>
        </div>
        <div class="card-body section-stack">
            <p class="upload-note">Выберите один или несколько файлов формата <strong>.ab1</strong>.</p>

            <form method="post" action="@Url.Page("/Project", new { id = Model.Id, handler = "Upload" })" enctype="multipart/form-data" class="section-stack">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />

                <div class="form-group mb-0">
                    <label for="UploadedFiles">Выберите файлы</label>
                    <input type="file" class="form-control" id="UploadedFiles" name="UploadedFiles" accept=".ab1" multiple />
                </div>

                <div>
                    <button type="submit" class="btn btn-primary">Загрузить</button>
                </div>
            </form>

            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
            {
                <div class="alert alert-danger">@Model.ErrorMessage</div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
            {
                <div class="alert alert-success">@Model.SuccessMessage</div>
            }
        </div>
    </section>

    <section class="card">
        <div class="card-header">
            <div>
                <h3>Риды текущего проекта</h3>
            </div>
        </div>
        <div class="card-body">
            @if (Model.Reads.Count == 0)
            {
                <div class="empty-state">
                    <h3>В проекте пока нет ридов</h3>
                    <p class="section-subtitle">После загрузки файлы появятся здесь, а логика отображения данных останется прежней.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-sm align-middle">
                        <thead>
                            <tr>
                                <th>Файл</th>
                                <th>Sample</th>
                                <th>Instrument</th>
                                <th>Длина</th>
                                <th>Direction</th>
                                <th>Последовательность</th>
                                <th>Дата</th>
                                <th>Удаление</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var read in Model.Reads.OrderByDescending(r => r.CreatedAt))
                            {
                                <tr>
                                    <td>@read.FileName</td>
                                    <td>@(read.SampleName ?? "-")</td>
                                    <td>@(read.InstrumentModel ?? "-")</td>
                                    <td>@read.SequenceLength</td>
                                    <td>@read.Direction</td>
                                    <td>
                                        <div class="sequence-preview">
                                            @(read.Sequence.Length > 120 ? read.Sequence[..120] + "..." : read.Sequence)
                                        </div>
                                    </td>
                                    <td>@read.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>
                                        <form method="post" action="@Url.Page("/Project", new { id = Model.Id, handler = "DeleteRead" })">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@Model.Id" />
                                            <input type="hidden" name="readId" value="@read.Id" />
                                            <button type="submit" class="btn btn-outline-danger btn-sm">Удалить</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </section>
</section>