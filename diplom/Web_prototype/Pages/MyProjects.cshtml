@page
@model Web_prototype.Pages.MyProjectsModel
@{
    ViewData["Title"] = "Мои проекты";
    Layout = "_Layout";
}

<section class="page-stack">
    <section class="dashboard-hero">
        <div class="dashboard-grid">
            <div class="dashboard-content">
                <span class="hero-badge">Личный кабинет</span>
                <h1 class="dashboard-title">Управление проектами и сборками</h1>

                <div class="dashboard-stats">
                    <div class="stat-pill">
                        <strong>@Model.Projects.Count</strong>
                        <span>Всего проектов</span>
                    </div>
                    <div class="stat-pill">
                        <strong>@(Model.Projects.Any() ? Model.Projects.Max(p => p.UpdatedAt).ToLocalTime().ToString("dd.MM") : "—")</strong>
                        <span>Последнее обновление</span>
                    </div>
                    <div class="stat-pill">
                        <strong>@(User.Identity?.Name ?? "User")</strong>
                        <span>Текущий пользователь</span>
                    </div>
                </div>
            </div>

            <div class="dashboard-side">
                <div class="info-card">
                    <span class="info-icon">➕</span>
                    <h3>Новый проект</h3>

                    <form method="post" action="@Url.Page("/MyProjects", new { handler = "Create" })" class="create-project-form mt-3">
                        @Html.AntiForgeryToken()

                        <div>
                            <label for="NewProjectTitle">Название проекта</label>
                            <input id="NewProjectTitle"
                                   type="text"
                                   name="NewProjectTitle"
                                   value="@Model.NewProjectTitle"
                                   class="form-control"
                                   placeholder="Например, Sample_2026_04" />
                        </div>

                        <button type="submit" class="btn btn-primary">Добавить проект</button>
                    </form>

                    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                    {
                        <div class="alert alert-danger">@Model.ErrorMessage</div>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
                    {
                        <div class="alert alert-success">@Model.SuccessMessage</div>
                    }
                </div>
            </div>
        </div>
    </section>

    <section class="card">
        <div class="card-header">
            <div>
                <h3>Мои проекты</h3>
            </div>
            <span id="projectsCount" class="text-muted small"></span>
        </div>

        <div class="card-body section-stack">
            @if (Model.Projects.Count == 0)
            {
                <div class="empty-state">
                    <h3>Проекты пока не созданы</h3>
                    <p class="section-subtitle">Создайте первый проект через форму выше — бизнес-логика и поведение останутся прежними.</p>
                </div>
            }
            else
            {
                <div class="filter-panel">
                    <div class="filter-grid">
                        <div>
                            <label for="searchTitle" class="form-label">Поиск по названию</label>
                            <input id="searchTitle"
                                   type="text"
                                   class="form-control"
                                   placeholder="Введите часть названия проекта"
                                   autocomplete="off" />
                        </div>

                        <div>
                            <label for="createdFrom" class="form-label">Дата создания: от</label>
                            <input id="createdFrom" type="date" class="form-control" />
                        </div>

                        <div>
                            <label for="createdTo" class="form-label">Дата создания: до</label>
                            <input id="createdTo" type="date" class="form-control" />
                        </div>

                        <div>
                            <label for="sortProjects" class="form-label">Сортировка</label>
                            <select id="sortProjects" class="form-select">
                                <option value="created_desc">Сначала новые</option>
                                <option value="created_asc">Сначала старые</option>
                                <option value="updated_desc">Недавно изменённые</option>
                                <option value="updated_asc">Давно не изменялись</option>
                                <option value="title_asc">Название А-Я</option>
                                <option value="title_desc">Название Я-А</option>
                            </select>
                        </div>
                    </div>

                    <div>
                        <button type="button" id="resetFilters" class="btn btn-outline-secondary btn-sm">Сбросить фильтры</button>
                    </div>
                </div>

                <p id="projectsEmpty" class="text-muted mb-3" style="display:none;">
                    Проекты по выбранным фильтрам не найдены.
                </p>

                <ul class="project-list list-group" id="projectsList">
                    @foreach (var project in Model.Projects)
                    {
                        <li class="project-item project-list-item list-group-item"
                            data-title="@project.Title"
                            data-created-at="@project.CreatedAt.ToString("yyyy-MM-ddTHH:mm:ss")"
                            data-updated-at="@project.UpdatedAt.ToString("yyyy-MM-ddTHH:mm:ss")">
                            <div class="project-meta">
                                <div class="project-title-row">
                                    <strong>@project.Title</strong>
                                    <span class="inline-badge">Проект</span>
                                </div>

                                <div class="project-date-grid">
                                    <div>Создан: @project.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</div>
                                    <div>Изменён: @project.UpdatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</div>
                                </div>
                            </div>

                            <a class="btn btn-outline-primary btn-sm" href="/Project/@project.Id">Открыть</a>
                        </li>
                    }
                </ul>
            }
        </div>
    </section>
</section>

@section Scripts
{
    <script>
        (() => {
            const list = document.getElementById('projectsList');
            if (!list) return;

            const searchInput = document.getElementById('searchTitle');
            const createdFromInput = document.getElementById('createdFrom');
            const createdToInput = document.getElementById('createdTo');
            const sortSelect = document.getElementById('sortProjects');
            const resetButton = document.getElementById('resetFilters');
            const emptyMessage = document.getElementById('projectsEmpty');
            const countLabel = document.getElementById('projectsCount');

            const allItems = Array.from(list.querySelectorAll('.project-item'));

            function parseDate(value) {
                return value ? new Date(value) : null;
            }

            function startOfDay(value) {
                if (!value) return null;
                return new Date(value + 'T00:00:00');
            }

            function endOfDay(value) {
                if (!value) return null;
                return new Date(value + 'T23:59:59.999');
            }

            function sortItems(items) {
                const sortValue = sortSelect.value;

                return items.sort((a, b) => {
                    const titleA = (a.dataset.title || '').toLowerCase();
                    const titleB = (b.dataset.title || '').toLowerCase();

                    const createdA = parseDate(a.dataset.createdAt);
                    const createdB = parseDate(b.dataset.createdAt);

                    const updatedA = parseDate(a.dataset.updatedAt);
                    const updatedB = parseDate(b.dataset.updatedAt);

                    switch (sortValue) {
                        case 'created_asc':
                            return createdA - createdB;

                        case 'updated_desc':
                            return updatedB - updatedA;

                        case 'updated_asc':
                            return updatedA - updatedB;

                        case 'title_asc':
                            return titleA.localeCompare(titleB, 'ru');

                        case 'title_desc':
                            return titleB.localeCompare(titleA, 'ru');

                        case 'created_desc':
                        default:
                            return createdB - createdA;
                    }
                });
            }

            function applyFilters() {
                const searchValue = (searchInput.value || '').trim().toLowerCase();
                const createdFrom = startOfDay(createdFromInput.value);
                const createdTo = endOfDay(createdToInput.value);

                let visibleItems = allItems.filter(item => {
                    const title = (item.dataset.title || '').toLowerCase();
                    const createdAt = parseDate(item.dataset.createdAt);

                    const matchesSearch =
                        !searchValue || title.includes(searchValue);

                    const matchesFrom =
                        !createdFrom || createdAt >= createdFrom;

                    const matchesTo =
                        !createdTo || createdAt <= createdTo;

                    return matchesSearch && matchesFrom && matchesTo;
                });

                allItems.forEach(item => {
                    item.style.display = 'none';
                });

                visibleItems = sortItems(visibleItems);

                visibleItems.forEach(item => {
                    item.style.display = '';
                    list.appendChild(item);
                });

                const count = visibleItems.length;
                countLabel.textContent = `Найдено: ${count}`;
                emptyMessage.style.display = count === 0 ? '' : 'none';
                list.style.display = count === 0 ? 'none' : '';
            }

            function debounce(fn, delay) {
                let timer = null;
                return function () {
                    clearTimeout(timer);
                    timer = setTimeout(fn, delay);
                };
            }

            const debouncedApply = debounce(applyFilters, 200);

            searchInput.addEventListener('input', debouncedApply);
            createdFromInput.addEventListener('change', applyFilters);
            createdToInput.addEventListener('change', applyFilters);
            sortSelect.addEventListener('change', applyFilters);

            resetButton.addEventListener('click', () => {
                searchInput.value = '';
                createdFromInput.value = '';
                createdToInput.value = '';
                sortSelect.value = 'created_desc';
                applyFilters();
            });

            sortSelect.value = 'created_desc';
            applyFilters();
        })();
    </script>
}