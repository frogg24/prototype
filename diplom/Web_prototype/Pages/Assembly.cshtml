@page "{projectId:int}"
@model Web_prototype.Pages.AssemblyModel
@{
    ViewData["Title"] = "Результаты сборки";
    Layout = "_Layout";
    ViewData["FullWidth"] = true;
}

<section class="workspace-shell">
    <section class="workspace-hero">
        <div class="workspace-hero-content">
            <h1 class="workspace-title">Результаты сборки</h1>

            <div class="workspace-actions">
                <a href="/MyProjects" class="btn btn-secondary btn-sm">К моим проектам</a>
                <a href="/Project/@Model.ProjectId" class="btn btn-outline-primary btn-sm">Назад в проект</a>
                <a href="/Assembly/@Model.ProjectId?handler=DownloadFasta&projectId=@Model.ProjectId" class="btn btn-success btn-sm">Скачать FASTA</a>
            </div>
        </div>
    </section>

    <div class="assembly-shell">
        <form method="post" id="antiForgeryForm">
            @Html.AntiForgeryToken()
        </form>

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="alert alert-warning">@Model.ErrorMessage</div>
        }
        else if (Model.Assembly != null)
        {
            <div class="assembly-viewer-card">
                <div class="assembly-toolbar">
                    <div class="zoom-group">
                        <strong>Масштаб</strong>
                        <button type="button" id="zoomOutBtn">−</button>
                        <input type="range" id="zoomRange" min="8" max="24" step="1" value="12" />
                        <button type="button" id="zoomInBtn">+</button>
                        <span id="zoomValue">12 px/base</span>
                    </div>

                    <div class="highlight-group">
                        <strong>Подсветка</strong>
                        <button type="button" class="highlight-btn active" data-base="">Все</button>
                        <button type="button" class="highlight-btn" data-base="A">A</button>
                        <button type="button" class="highlight-btn" data-base="C">C</button>
                        <button type="button" class="highlight-btn" data-base="G">G</button>
                        <button type="button" class="highlight-btn" data-base="T">T</button>
                    </div>

                    <div class="peak-group">
                        <strong>Пики</strong>
                        <button type="button" id="smallerPeaksBtn">Меньше</button>
                        <button type="button" id="biggerPeaksBtn">Больше</button>
                        <button type="button" id="resetPeaksBtn">Сброс</button>
                        <span id="peakScaleValue">1.0x</span>
                    </div>

                    <div class="quality-group">
                        <strong>Low-Q</strong>
                        <button type="button" id="toggleLowQualityBtn" class="active">Показывать</button>
                        <label for="lowQualityThreshold" class="mb-0">Порог</label>
                        <input type="range" id="lowQualityThreshold" min="5" max="40" step="1" value="20" />
                        <span id="lowQualityThresholdValue">Q20</span>
                    </div>

                    <div class="edit-group">
                        <strong>Consensus</strong>
                        <button type="button" id="editConsensusBtn">Редактировать</button>
                        <button type="button" id="saveConsensusBtn" disabled>Сохранить</button>
                        <button type="button" id="cancelConsensusBtn" disabled>Отмена</button>
                        <span id="editStatusText">view mode</span>
                    </div>
                </div>

                <div class="assembly-scroll" id="assemblyScroll">
                    <div class="assembly-content" id="assemblyContent"></div>
                </div>
            </div>

        }
    </div>
</section>

<script>
    (() => {
        const viewerData = @Html.Raw(Model.ViewerJson ?? "null");
        if (!viewerData || !viewerData.consensusSequence) {
            return;
        }

        const content = document.getElementById("assemblyContent");
        const zoomRange = document.getElementById("zoomRange");
        const zoomValue = document.getElementById("zoomValue");
        const zoomOutBtn = document.getElementById("zoomOutBtn");
        const zoomInBtn = document.getElementById("zoomInBtn");
        const highlightButtons = Array.from(document.querySelectorAll(".highlight-btn"));

        const smallerPeaksBtn = document.getElementById("smallerPeaksBtn");
        const biggerPeaksBtn = document.getElementById("biggerPeaksBtn");
        const resetPeaksBtn = document.getElementById("resetPeaksBtn");
        const peakScaleValue = document.getElementById("peakScaleValue");

        const toggleLowQualityBtn = document.getElementById("toggleLowQualityBtn");
        const lowQualityThreshold = document.getElementById("lowQualityThreshold");
        const lowQualityThresholdValue = document.getElementById("lowQualityThresholdValue");

        const editConsensusBtn = document.getElementById("editConsensusBtn");
        const saveConsensusBtn = document.getElementById("saveConsensusBtn");
        const cancelConsensusBtn = document.getElementById("cancelConsensusBtn");
        const editStatusText = document.getElementById("editStatusText");
        const antiForgeryToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value || "";

        const assemblyId = @Model.Assembly?.Id ?? 0;
        const projectId = @Model.ProjectId;

        let editMode = false;
        let selectedConsensusIndex = null;
        let originalConsensusSequence = viewerData.consensusSequence || "";
        let editedConsensusSequence = originalConsensusSequence.split("");

        const baseColors = {
            A: "#2e8b57",
            C: "#1f77b4",
            G: "#222222",
            T: "#d62728",
            N: "#6c757d"
        };

        let baseWidth = Number(zoomRange.value);
        let highlightedBase = "";
        let peakScale = 1.0;
        let showLowQuality = true;
        let consensusLowQThreshold = Number(lowQualityThreshold.value);

        function setPeakScale(nextValue) {
            peakScale = Math.max(0.25, Math.min(8.0, Number(nextValue)));
            peakScaleValue.textContent = `${peakScale.toFixed(1)}x`;
            renderViewer();
        }

        function normalizeBase(ch) {
            const up = String(ch || "N").toUpperCase();
            return ["A", "C", "G", "T"].includes(up) ? up : "N";
        }

        function setZoom(nextValue) {
            baseWidth = Math.max(8, Math.min(24, Number(nextValue)));
            zoomRange.value = String(baseWidth);
            zoomValue.textContent = `${baseWidth} px/base`;
            renderViewer();
        }

        function setHighlight(base) {
            highlightedBase = base || "";
            highlightButtons.forEach(btn => {
                btn.classList.toggle("active", btn.dataset.base === highlightedBase);
            });
            renderViewer();
        }

        function createBaseRow(sequence, qualities = null, options = {}) {
            const row = document.createElement("div");
            row.className = "sequence-row";

            const useLowQuality = !!options.useLowQuality;
            const editable = !!options.editable;
            const onBaseClick = options.onBaseClick || null;
            const selectedIndex = Number.isInteger(options.selectedIndex) ? options.selectedIndex : -1;
            const modifiedIndexes = options.modifiedIndexes || new Set();

            for (let i = 0; i < sequence.length; i++) {
                const ch = sequence[i];
                const base = normalizeBase(ch);
                const span = document.createElement("span");
                span.className = `base-char base-${base}`;

                if (highlightedBase && base !== highlightedBase) {
                    span.classList.add("base-dim");
                }

                if (useLowQuality && showLowQuality && qualities && i < qualities.length) {
                    const q = Number(qualities[i]);

                    if (q < consensusLowQThreshold) {
                        span.classList.add("low-quality-base");
                    }

                    if (q < Math.max(5, consensusLowQThreshold - 8)) {
                        span.classList.add("very-low-quality-base");
                    }

                    span.title = `Base: ${ch}, Q: ${q}`;
                }

                if (editable) {
                    span.classList.add("editable-base");
                    span.dataset.index = String(i);

                    if (i === selectedIndex) {
                        span.classList.add("selected-base");
                    }

                    if (modifiedIndexes.has(i)) {
                        span.classList.add("modified-base");
                    }

                    span.addEventListener("click", () => {
                        if (typeof onBaseClick === "function") {
                            onBaseClick(i);
                        }
                    });
                }

                span.textContent = ch;
                row.appendChild(span);
            }

            return row;
        }

        function buildLaneBlock(title, meta) {
            const block = document.createElement("div");
            block.className = "lane-block";

            const header = document.createElement("div");
            header.className = "lane-header";

            const titleEl = document.createElement("div");
            titleEl.className = "lane-title";
            titleEl.textContent = title;

            const metaEl = document.createElement("div");
            metaEl.className = "lane-meta";
            metaEl.textContent = meta;

            header.appendChild(titleEl);
            header.appendChild(metaEl);
            block.appendChild(header);

            return { block, header };
        }

        function buildRuler(totalWidth) {
            const ruler = document.createElement("div");
            ruler.className = "lane-canvas ruler-track";
            ruler.style.width = `${totalWidth}px`;

            const step = 10;
            for (let pos = 0; pos <= viewerData.consensusLength; pos += step) {
                const x = pos * baseWidth;

                const tick = document.createElement("div");
                tick.className = "ruler-tick";
                tick.style.left = `${x}px`;
                ruler.appendChild(tick);

                if (pos < viewerData.consensusLength) {
                    const label = document.createElement("div");
                    label.className = "ruler-label";
                    label.style.left = `${x}px`;
                    label.textContent = String(pos);
                    ruler.appendChild(label);
                }
            }

            return ruler;
        }

        function buildConsensusLane(totalWidth) {
            const lane = document.createElement("div");
            lane.className = "lane-canvas consensus";
            lane.style.width = `${totalWidth}px`;

            const currentSequence = editedConsensusSequence.join("");
            const modifiedIndexes = new Set();

            for (let i = 0; i < currentSequence.length; i++) {
                if (currentSequence[i] !== originalConsensusSequence[i]) {
                    modifiedIndexes.add(i);
                }
            }

            lane.appendChild(
                createBaseRow(
                    currentSequence,
                    viewerData.consensusQualities || [],
                    {
                        useLowQuality: true,
                        editable: editMode,
                        selectedIndex: selectedConsensusIndex,
                        modifiedIndexes,
                        onBaseClick: (index) => {
                            if (!editMode) {
                                return;
                            }

                            selectedConsensusIndex = index;
                            editStatusText.textContent = `selected base: ${index}`;
                            renderViewer();
                        }
                    }
                )
            );

            return lane;
        }

        function buildPolyline(values, width, height, color, maxValue) {
            if (!values || values.length === 0 || width <= 0) {
                return null;
            }

            const ns = "http://www.w3.org/2000/svg";
            const polyline = document.createElementNS(ns, "polyline");
            polyline.setAttribute("fill", "none");
            polyline.setAttribute("stroke", color);
            polyline.setAttribute("stroke-width", "1.5");
            polyline.setAttribute("stroke-linejoin", "round");
            polyline.setAttribute("stroke-linecap", "round");

            const effectiveMax = Math.max(1, maxValue / peakScale);
            const maxPoints = Math.max(1200, Math.floor(width * 2));
            const stride = Math.max(1, Math.ceil(values.length / maxPoints));
            const points = [];

            for (let i = 0; i < values.length; i += stride) {
                const x = values.length === 1 ? 0 : (i / (values.length - 1)) * width;
                const rawY = height - 6 - ((values[i] || 0) / effectiveMax) * (height - 12);
                const y = Math.max(4, Math.min(height - 6, rawY));
                points.push(`${x.toFixed(2)},${y.toFixed(2)}`);
            }

            if ((values.length - 1) % stride !== 0) {
                const lastIndex = values.length - 1;
                const x = width;
                const rawY = height - 6 - ((values[lastIndex] || 0) / effectiveMax) * (height - 12);
                const y = Math.max(4, Math.min(height - 6, rawY));
                points.push(`${x.toFixed(2)},${y.toFixed(2)}`);
            }

            polyline.setAttribute("points", points.join(" "));
            polyline.setAttribute("opacity", highlightedBase && color !== baseColors[highlightedBase] ? "0.18" : "0.95");
            return polyline;
        }

        function enterEditMode() {
            editMode = true;
            selectedConsensusIndex = null;
            saveConsensusBtn.disabled = false;
            cancelConsensusBtn.disabled = false;
            editStatusText.textContent = "edit mode";
            renderViewer();
        }

        async function saveConsensusChanges() {
            const newConsensus = editedConsensusSequence.join("");

            if (!newConsensus || assemblyId <= 0) {
                return;
            }

            saveConsensusBtn.disabled = true;
            editStatusText.textContent = "saving...";

            try {
                const response = await fetch(`?handler=SaveConsensus`, {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                        "RequestVerificationToken": antiForgeryToken
                    },
                    body: JSON.stringify({
                        assemblyId: assemblyId,
                        projectId: projectId,
                        consensusSequence: newConsensus
                    })
                });

                const rawText = await response.text();
                let payload = null;

                if (rawText && rawText.trim().length > 0) {
                    try {
                        payload = JSON.parse(rawText);
                    } catch {
                        payload = null;
                    }
                }

                if (!response.ok) {
                    throw new Error(payload?.message || rawText || `HTTP ${response.status}`);
                }

                if (!payload) {
                    throw new Error("Сервер вернул пустой ответ");
                }

                originalConsensusSequence = payload.consensusSequence;
                editedConsensusSequence = payload.consensusSequence.split("");
                viewerData.consensusSequence = payload.consensusSequence;
                viewerData.consensusLength = payload.consensusLength;

                exitEditMode(false);
                editStatusText.textContent = "saved";
            } catch (error) {
                console.error(error);
                editStatusText.textContent = "save failed";
                saveConsensusBtn.disabled = false;
                alert(error.message || "Ошибка при сохранении consensus");
            }
        }

        function exitEditMode(resetChanges) {
            if (resetChanges) {
                editedConsensusSequence = originalConsensusSequence.split("");
            }

            editMode = false;
            selectedConsensusIndex = null;
            saveConsensusBtn.disabled = true;
            cancelConsensusBtn.disabled = true;
            editStatusText.textContent = "view mode";
            renderViewer();
        }

        function replaceSelectedBase(newBase) {
            if (!editMode || selectedConsensusIndex === null) {
                return;
            }

            const up = String(newBase || "").toUpperCase();
            if (!["A", "C", "G", "T", "N"].includes(up)) {
                return;
            }

            editedConsensusSequence[selectedConsensusIndex] = up;
            renderViewer();
        }

        function buildChromatogram(track, width) {
            const height = 128;
            const wrapper = document.createElement("div");
            wrapper.className = "chrom-wrapper";
            wrapper.style.width = `${width}px`;
            wrapper.style.height = `${height}px`;

            const ns = "http://www.w3.org/2000/svg";
            const svg = document.createElementNS(ns, "svg");
            svg.setAttribute("class", "chrom-svg");
            svg.setAttribute("width", width);
            svg.setAttribute("height", height);
            svg.setAttribute("viewBox", `0 0 ${Math.max(width, 1)} ${height}`);

            const baseline = document.createElementNS(ns, "line");
            baseline.setAttribute("x1", "0");
            baseline.setAttribute("x2", String(Math.max(width, 1)));
            baseline.setAttribute("y1", String(height - 6));
            baseline.setAttribute("y2", String(height - 6));
            baseline.setAttribute("stroke", "#adb5bd");
            baseline.setAttribute("stroke-width", "1");
            svg.appendChild(baseline);

            const allValues = []
                .concat(track.traces?.a || [])
                .concat(track.traces?.c || [])
                .concat(track.traces?.g || [])
                .concat(track.traces?.t || []);
            const maxValue = allValues.length ? Math.max(...allValues, 1) : 1;

            const channelOrder = [
                { base: "A", values: track.traces?.a || [] },
                { base: "C", values: track.traces?.c || [] },
                { base: "G", values: track.traces?.g || [] },
                { base: "T", values: track.traces?.t || [] }
            ];

            for (const channel of channelOrder) {
                const polyline = buildPolyline(channel.values, width, height, baseColors[channel.base], maxValue);
                if (polyline) {
                    svg.appendChild(polyline);
                }
            }

            const labels = document.createElement("div");
            labels.className = "trace-labels";
            for (const base of ["A", "C", "G", "T"]) {
                const span = document.createElement("span");
                span.dataset.base = base;
                span.textContent = base;
                if (highlightedBase && highlightedBase !== base) {
                    span.style.opacity = "0.2";
                }
                labels.appendChild(span);
            }

            wrapper.appendChild(svg);
            wrapper.appendChild(labels);
            return wrapper;
        }

        function buildReadBlock(track, totalWidth) {
            const orientation = track.wasReversed ? "R" : "F";
            const title = `${track.fileName} · read ${track.readId}`;
            const meta = `${orientation} · ${track.start}-${track.end} · ${track.visibleLength} bp`;
            const { block } = buildLaneBlock(title, meta);

            const sequenceLane = document.createElement("div");
            sequenceLane.className = "lane-canvas";
            sequenceLane.style.width = `${totalWidth}px`;
            sequenceLane.style.height = "32px";

            const placedSequence = document.createElement("div");
            placedSequence.className = "placed-sequence";
            placedSequence.style.left = `${track.start * baseWidth}px`;
            placedSequence.appendChild(createBaseRow(track.sequence));
            sequenceLane.appendChild(placedSequence);

            const chromLane = document.createElement("div");
            chromLane.className = "lane-canvas";
            chromLane.style.width = `${totalWidth}px`;
            chromLane.style.height = "128px";

            const placedChrom = document.createElement("div");
            placedChrom.className = "placed-chromatogram";
            placedChrom.style.left = `${track.start * baseWidth}px`;
            placedChrom.appendChild(buildChromatogram(track, track.visibleLength * baseWidth));
            chromLane.appendChild(placedChrom);

            block.appendChild(sequenceLane);
            block.appendChild(chromLane);
            return block;
        }

        function renderViewer() {
            const totalWidth = viewerData.consensusLength * baseWidth;
            content.innerHTML = "";
            content.style.setProperty("--base-width", `${baseWidth}px`);

            const rulerBlock = buildLaneBlock("Координаты", `0-${viewerData.consensusLength}`);
            rulerBlock.block.appendChild(buildRuler(totalWidth));
            content.appendChild(rulerBlock.block);

            const consensusBlock = buildLaneBlock("Consensus", `${viewerData.consensusLength} bp`);
            consensusBlock.block.appendChild(buildConsensusLane(totalWidth));
            content.appendChild(consensusBlock.block);

            for (const track of viewerData.tracks || []) {
                content.appendChild(buildReadBlock(track, totalWidth));
            }
        }

        function animateButtonPress(button) {
            if (!button) {
                return;
            }

            button.classList.remove("button-pop");
            void button.offsetWidth;
            button.classList.add("button-pop");
        }

        zoomRange.addEventListener("input", (e) => setZoom(e.target.value));
        zoomOutBtn.addEventListener("click", () => setZoom(baseWidth - 1));
        zoomInBtn.addEventListener("click", () => setZoom(baseWidth + 1));

        highlightButtons.forEach(btn => {
            btn.addEventListener("click", () => setHighlight(btn.dataset.base || ""));
        });

        smallerPeaksBtn.addEventListener("click", () => {
            animateButtonPress(smallerPeaksBtn);
            setPeakScale(peakScale - 0.25);
        });

        biggerPeaksBtn.addEventListener("click", () => {
            animateButtonPress(biggerPeaksBtn);
            setPeakScale(peakScale + 0.25);
        });

        resetPeaksBtn.addEventListener("click", () => {
            animateButtonPress(resetPeaksBtn);
            setPeakScale(1.0);
        });

        toggleLowQualityBtn.addEventListener("click", () => {
            showLowQuality = !showLowQuality;
            toggleLowQualityBtn.classList.toggle("active", showLowQuality);
            renderViewer();
        });

        lowQualityThreshold.addEventListener("input", (e) => {
            consensusLowQThreshold = Number(e.target.value);
            lowQualityThresholdValue.textContent = `Q${consensusLowQThreshold}`;
            renderViewer();
        });

        document.addEventListener("keydown", (event) => {
            if (!editMode) {
                return;
            }

            const key = event.key.toUpperCase();

            if (["A", "C", "G", "T", "N"].includes(key)) {
                replaceSelectedBase(key);
                event.preventDefault();
                return;
            }

            if (event.key === "ArrowLeft" && selectedConsensusIndex !== null && selectedConsensusIndex > 0) {
                selectedConsensusIndex--;
                renderViewer();
                event.preventDefault();
                return;
            }

            if (event.key === "ArrowRight" && selectedConsensusIndex !== null && selectedConsensusIndex < editedConsensusSequence.length - 1) {
                selectedConsensusIndex++;
                renderViewer();
                event.preventDefault();
                return;
            }

            if (event.key === "Escape") {
                exitEditMode(true);
                event.preventDefault();
                return;
            }

            if (event.ctrlKey && event.key.toLowerCase() === "s") {
                saveConsensusChanges();
                event.preventDefault();
            }
        });

    editConsensusBtn.addEventListener("click", () => {
        if (editMode) {
            exitEditMode(false);
        } else {
            enterEditMode();
        }
    });

    saveConsensusBtn.addEventListener("click", async () => {
        await saveConsensusChanges();
    });

    cancelConsensusBtn.addEventListener("click", () => {
        exitEditMode(true);
    });

        lowQualityThresholdValue.textContent = `Q${consensusLowQThreshold}`;
        toggleLowQualityBtn.classList.toggle("active", showLowQuality);

        peakScaleValue.textContent = `${peakScale.toFixed(1)}x`;

        renderViewer();
    })();
</script>