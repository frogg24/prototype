@page
@model Web_prototype.Pages.RegisterModel
@{
    ViewData["Title"] = "Register";
    Layout = "_Layout";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h3>Регистрация</h3>
            </div>
            <div class="card-body">
                @Html.ValidationSummary(excludePropertyErrors: true, message: string.Empty, htmlAttributes: new { @class = "text-danger" })

                <form method="post">
                    @Html.AntiForgeryToken()
                    <div class="form-group">
                        <label for="Input_Username">Имя пользователя:</label>
                        @Html.TextBoxFor(m => m.Input.Username, new { @class = "form-control", id = "Input_Username" })
                        @Html.ValidationMessageFor(m => m.Input.Username, string.Empty, new { @class = "text-danger" })
                    </div>
                    <div class="form-group">
                        <label for="Input_Email">Эл. почта:</label>
                        @Html.TextBoxFor(m => m.Input.Email, new { @class = "form-control", id = "Input_Email", type = "email" })
                        @Html.ValidationMessageFor(m => m.Input.Email, string.Empty, new { @class = "text-danger" })
                    </div>
                    <div class="form-group">
                        <label for="Input_Password">Пароль:</label>
                        @Html.PasswordFor(m => m.Input.Password, new { @class = "form-control", id = "Input_Password" })
                        @Html.ValidationMessageFor(m => m.Input.Password, string.Empty, new { @class = "text-danger" })
                    </div>
                    <div class="form-group">
                        <label for="Input_ConfirmPassword">Подтверждение пароля:</label>
                        @Html.PasswordFor(m => m.Input.ConfirmPassword, new { @class = "form-control", id = "Input_ConfirmPassword" })
                        @Html.ValidationMessageFor(m => m.Input.ConfirmPassword, string.Empty, new { @class = "text-danger" })
                    </div>
                    <button type="submit" class="btn btn-primary">Регистрация</button>
                </form>
                <hr />
                <p>Уже есть аккаунт? <a href="/Login">Войти</a></p>
            </div>
        </div>
    </div>
</div>