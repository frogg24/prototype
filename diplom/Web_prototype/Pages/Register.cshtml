@page
@model Web_prototype.Pages.RegisterModel
@{
    ViewData["Title"] = "Регистрация";
    Layout = "_Layout";
}

<section class="auth-shell">
    <div class="auth-card">
        <aside class="auth-aside">
            <div>
                <span class="hero-badge">Новый аккаунт</span>
                <h1 class="auth-title">Создайте рабочее пространство для геномных проектов</h1>
                <p class="auth-text">
                    После регистрации вы сможете создавать проекты, загружать риды и использовать все текущие возможности приложения в обновлённом интерфейсе.
                </p>
            </div>

        </aside>

        <div class="auth-form-panel">
            <div class="section-stack">
                <div>
                    <span class="section-badge">Регистрация</span>
                    <h2>Создание аккаунта</h2>
                    <p class="section-subtitle">Заполните поля ниже. Логика регистрации и проверки данных остаётся прежней.</p>
                </div>

                @Html.ValidationSummary(excludePropertyErrors: true, message: string.Empty, htmlAttributes: new { @class = "text-danger" })

                <form method="post" class="auth-form">
                    @Html.AntiForgeryToken()

                    <div class="form-group">
                        <label for="Input_Username">Имя пользователя</label>
                        @Html.TextBoxFor(m => m.Input.Username, new { @class = "form-control", id = "Input_Username", placeholder = "Например, bio_user" })
                        @Html.ValidationMessageFor(m => m.Input.Username, string.Empty, new { @class = "text-danger" })
                    </div>

                    <div class="form-group">
                        <label for="Input_Email">Эл. почта</label>
                        @Html.TextBoxFor(m => m.Input.Email, new { @class = "form-control", id = "Input_Email", type = "email", placeholder = "name@example.com" })
                        @Html.ValidationMessageFor(m => m.Input.Email, string.Empty, new { @class = "text-danger" })
                    </div>

                    <div class="form-group">
                        <label for="Input_Password">Пароль</label>
                        @Html.PasswordFor(m => m.Input.Password, new { @class = "form-control", id = "Input_Password", placeholder = "Введите пароль" })
                        @Html.ValidationMessageFor(m => m.Input.Password, string.Empty, new { @class = "text-danger" })
                    </div>

                    <div class="form-group">
                        <label for="Input_ConfirmPassword">Подтверждение пароля</label>
                        @Html.PasswordFor(m => m.Input.ConfirmPassword, new { @class = "form-control", id = "Input_ConfirmPassword", placeholder = "Повторите пароль" })
                        @Html.ValidationMessageFor(m => m.Input.ConfirmPassword, string.Empty, new { @class = "text-danger" })
                    </div>

                    <button type="submit" class="btn btn-primary">Зарегистрироваться</button>
                </form>

                <div class="auth-footer">
                    <span>Уже есть аккаунт?</span>
                    <a href="/Login">Войти</a>
                </div>
            </div>
        </div>
    </div>
</section>