@page
@{
    ViewData["Title"] = "Upload Reads";
    Layout = "_Layout";
}

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h3>Загрузить риды</h3>
            </div>
            <div class="card-body">
                <p>Загрузите один или несколько файлов .ab1 (чтения Сэнгера) для выполнения сборки генома</p>

                <form id="uploadForm" method="post" enctype="multipart/form-data">
                    <div class="form-group">
                        <label for="fileInput">Выберите .ab1 файлы:</label>
                        <input type="file" class="form-control" id="fileInput" name="files" multiple accept=".ab1" />
                        <small class="form-text text-muted">Обработка файлов будет доступна после подключения серверной логики.</small>
                    </div>
                    <button type="submit" class="btn btn-primary">Загрузить и начать сборку</button>
                </form>

            </div>
        </div>
    </div>
</div>